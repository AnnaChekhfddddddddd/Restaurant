@model Restaurant.Models.Food

@{
    ViewData["Title"] = "Додати страву";
}

<h2 class="mt-4 mb-4">Додати нову страву</h2>
<hr />

<div class="row">
    <div class="col-md-5">
        <form asp-action="Create" enctype="multipart/form-data" class="p-3 bg-light rounded shadow-sm">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label fw-bold mb-1">Назва</label>
                <input asp-for="Name" class="form-control" style="padding: 0.6rem;" placeholder="Введіть назву страви..." />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="FoodTypeID" class="control-label fw-bold mb-1">Категорія</label>
                <select asp-for="FoodTypeID" class="form-select" asp-items="ViewBag.FoodTypeID" style="padding: 0.6rem; height: auto; min-height: 45px;"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Price" class="control-label fw-bold mb-1">Ціна (₴)</label>
                <input asp-for="Price" class="form-control" style="padding: 0.6rem;" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="Image" class="control-label fw-bold mb-1">Зображення</label>
                <input type="file" name="file" asp-for="Image" class="form-control" style="padding: 0.6rem; height: auto; min-height: 45px;" />
                <span asp-validation-for="Image" class="text-danger"></span>
            </div>

            <div class="form-group mt-2 mb-2">
                <button type="submit" class="btn btn-warning fw-bold px-5 py-2 rounded-pill shadow-sm" style="background-color: #ffb142; border: none; color: white; font-size: 1.1rem;">
                    Додати страву
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
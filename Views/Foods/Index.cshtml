@model IEnumerable<Restaurant.Models.Food>

@{
    ViewData["Title"] = "Меню";
    var groupedMenu = Model.GroupBy(x => x.FoodType?.Name ?? "Інше").ToList();
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<div class="container mt-4 page-transition">

    @* 1. ЗАГОЛОВОК СТОРІНКИ *@
    <div class="text-center mb-4">
        <h1 class="display-5 fw-normal m-0">Наше Меню</h1>
        <p class="text-muted small m-0">Обирайте найкраще, ми приготуємо це з любов'ю</p>
    </div>

    @* 2. ГОРТИННИЙ СКРОЛ КАТЕГОРІЙ *@
    <div class="category-scroll-container mb-4">
        <div class="category-scroll-wrapper" id="categoryScroll">
            <a asp-action="Index" class="category-item @(ViewData["CategoryID"] == null ? "active" : "")">Всі страви</a>
            @if (ViewData["AllCategories"] != null)
            {
                @foreach (var type in (SelectList)ViewData["AllCategories"])
                {
                    <a asp-action="Index" asp-route-CategoryID="@type.Value"
                       class="category-item @(ViewData["CategoryID"]?.ToString() == type.Value ? "active" : "")">
                        @type.Text
                    </a>
                }
            }
        </div>
    </div>

    @* 3. СПИСОК СТРАВ ПО КАТЕГОРІЯХ *@
    @foreach (var category in groupedMenu)
    {
        <div class="d-flex justify-content-between align-items-center mt-5 mb-4 border-bottom pb-2">
            <h3 class="m-0 fw-normal text-dark">@category.Key</h3>

            @if (User.IsInRole("Менеджер"))
            {
                <a asp-action="Create" class="btn btn-success btn-sm rounded-pill px-3 shadow-sm d-flex align-items-center"
                   style="background-color: #27ae60; border: none; font-weight: 600;">
                    <i class="fa-solid fa-plus me-2"></i> Додати страву
                </a>
            }
        </div>

        <div class="row">
            @foreach (var item in category)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 border-0 shadow-sm @(item.IsAvailable ? "" : "opacity-75")" style="border-radius: 15px; overflow: hidden;">
                        <div class="position-relative">
                            <img src="@item.Image" class="card-img-top" style="height: 200px; object-fit: cover; @(item.IsAvailable ? "" : "filter: grayscale(0.6);")">
                            @if (!item.IsAvailable)
                            {
                                <div class="sold-out-overlay">
                                    <span class="badge bg-danger fs-6 px-3 shadow">Sold Out</span>
                                </div>
                            }
                        </div>

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold">@item.Name</h5>
                            <div class="mt-auto">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="fs-5 fw-bold text-warning">@item.Price ₴</span>

                                    @* НОВА КНОПКА БЕЗ ПЕРЕЗАВАНТАЖЕННЯ *@
                                    @if (item.IsAvailable && !User.IsInRole("Менеджер"))
                                    {
                                        <button type="button"
                                                class="btn btn-dark btn-sm rounded-pill px-3 shadow-sm add-to-cart-btn"
                                                data-id="@item.ID">
                                            До кошика
                                        </button>
                                    }
                                </div>

                                @if (User.IsInRole("Менеджер"))
                                {
                                    <div class="d-flex gap-1 mt-2 pt-2 border-top">
                                        <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-sm btn-outline-primary shadow-sm"><i class="fa-solid fa-pen"></i></a>
                                        <a asp-action="ToggleStatus" asp-route-id="@item.ID" class="btn btn-sm @(item.IsAvailable ? "btn-outline-warning" : "btn-warning") flex-grow-1 shadow-sm">
                                            @(item.IsAvailable ? "В солдаут" : "Активувати")
                                        </a>
                                        <button type="button" onclick="confirmDeleteAction('@item.ID')" class="btn btn-sm btn-outline-danger shadow-sm"><i class="fa-solid fa-trash"></i></button>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // 1. Плавний скрол категорій
            const container = document.querySelector('.category-scroll-container');
            const activeItem = document.querySelector('.category-item.active');
            if (activeItem && container) {
                const scrollPos = activeItem.offsetLeft - (container.offsetWidth / 2) + (activeItem.offsetWidth / 2);
                container.scrollTo({ left: scrollPos, behavior: 'smooth' });
            }

            // 2. ЄДИНИЙ ТА ПРАВИЛЬНИЙ ОБРОБНИК КОШИКА
            $('.add-to-cart-btn').off('click').click(function (e) {
                e.preventDefault();

                var button = $(this);
                var foodId = button.data('id');

                $.post('/Cart/AddToCart', { id: foodId }, function (data) {
                    // Анімація кнопки (зміна тексту на "Додано!")
                    var originalText = button.text();
                    button.text('Додано!').removeClass('btn-dark').addClass('btn-success');

                    setTimeout(function () {
                        button.text(originalText).removeClass('btn-success').addClass('btn-dark');
                    }, 800);

                    // ОНОВЛЕННЯ ЦИФРИ (використовуємо правильний ID з вашого Layout)
                    var badge = $("#cart-badge");
                    if (badge.length) {
                        badge.text(data.count); // Беремо точну цифру, яку прислав контролер

                        // Показуємо бейдж, якщо він був прихований
                        if (data.count > 0) {
                            badge.removeClass("d-none");
                        }
                    }
                }).fail(function () {
                    alert('Помилка при додаванні до кошика');
                });
            });
        });

        // 3. Логіка видалення для менеджера
        function confirmDeleteAction(id) {
            const password = prompt("Введіть пароль менеджера (manager123) для видалення:");
            if (password === "manager123") {
                if (confirm("Видалити цю страву назавжди?")) {
                    window.location.href = "/Foods/DeleteConfirmedQuickly/" + id;
                }
            } else if (password !== null) {
                alert("Невірний пароль!");
            }
        }
    </script>
}

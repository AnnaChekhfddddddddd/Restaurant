@model Restaurant.Models.Food

@{
    ViewData["Title"] = "Деталі страви";
}

<div class="container mt-4">
    <h2>Деталі страви</h2>
    <hr />
    <dl class="row">

        <dt class="col-sm-2">
            Назва
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>

        <dt class="col-sm-2">
            Зображення
        </dt>
        <dd class="col-sm-10">
            @if (!string.IsNullOrEmpty(Model.Image))
            {
                <img src="@Model.Image" alt="food photo" class="img-thumbnail" style="max-width: 300px;" />
            }
            else
            {
                <span>Зображення відсутнє</span>
            }
        </dd>

        <dt class="col-sm-2">
            Категорія
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.FoodType.Name)
        </dd>

        <dt class="col-sm-2">
            Ціна
        </dt>
        <dd class="col-sm-10">
            <strong>@Model.Price грн.</strong>
        </dd>

        <dt class="col-sm-2">
            Наявність
        </dt>
        <dd class="col-sm-10">
            @if (Model.IsAvailable)
            {
                <span class="badge badge-success">В наявності</span>
            }
            else
            {
                <span class="badge badge-danger">Немає</span>
            }
        </dd>
    </dl>
</div>

<div class="mt-3">
    @if (User.Identity.IsAuthenticated && User.IsInRole("Менеджер"))
    {
        <a asp-action="Edit" asp-route-id="@Model.ID" class="btn btn-warning">Редагувати</a>
    }
    <a asp-action="Index" class="btn btn-secondary">Назад до меню</a>
</div>
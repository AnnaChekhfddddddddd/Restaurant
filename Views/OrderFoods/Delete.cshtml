@model Restaurant.Models.OrderFood

@{
    ViewData["Title"] = "Delete";
}



<h3>Видалити блюдо із замовлення?</h3>
<div>
    
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            Замовлення
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Order.ID)
        </dd class>
        <dt class = "col-sm-2">
            Блюдо
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Food.Name)
        </dd class>
        <dt class = "col-sm-2">
            Кількість
        </dt>
        <dd class = "col-sm-10">
    @Html.DisplayFor(model => model.Quantity)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="ID" />
        <input type="submit" value="Видалити" class="btn btn-danger" /> |
    </form>
</div>

@model List<Restaurant.Models.CartItem>

@{
    ViewData["Title"] = "Замовлення прийнято";
}

<div class="container mt-5">
    <div class="card shadow border-0 text-center p-5" style="border-radius: 20px; background-color: #ffffff;">
        <div class="mb-4">
            @* Велика зелена галочка або анімована іконка *@
            <i class="fa-solid fa-circle-check text-success" style="font-size: 5rem;"></i>
        </div>

        <h1 class="fw-bold mb-3">Дякуємо за замовлення!</h1>
        <p class="text-muted fs-5 mb-4">Ваші страви вже готуються. Очікуйте на подачу найближчим часом.</p>

        <div class="text-start mx-auto" style="max-width: 600px;">
            <div class="p-4 bg-light rounded-3">
                <h5 class="fw-bold border-bottom pb-2 mb-3">Ваш чек (сплачено):</h5>

                @foreach (var item in Model)
                {
                    <div class="d-flex justify-content-between mb-2">
                        <span>@item.Name <small class="text-muted">x @item.Quantity</small></span>
                        <span class="fw-bold">@(item.Price * item.Quantity) грн</span>
                    </div>
                }

                <div class="d-flex justify-content-between border-top pt-2 mt-2">
                    <span class="fs-4 fw-bold">Разом:</span>
                    <span class="fs-4 fw-bold text-warning">@Model.Sum(x => x.Price * x.Quantity) грн</span>
                </div>
            </div>
        </div>

        <div class="mt-5">
            <a asp-controller="Foods" asp-action="Index" class="btn btn-warning btn-lg px-5 rounded-pill fw-bold shadow-sm">
                ПОВЕРНУТИСЯ ДО МЕНЮ
            </a>
        </div>
    </div>
</div>
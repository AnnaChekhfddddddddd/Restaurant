@model IEnumerable<Restaurant.Models.Order>

@{
    ViewData["Title"] = "Мої замовлення";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Історія замовлень</h2>
        <a asp-controller="Foods" asp-action="Index" class="btn btn-outline-dark rounded-pill">
            <i class="fa-solid fa-plus me-1"></i> Нове замовлення
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="card shadow-sm border-0 rounded-3 p-5 text-center">
            <i class="fa-solid fa-clock-rotate-left fa-3x text-muted mb-3"></i>
            <p class="lead text-muted">Ви ще не робили замовлень.</p>
        </div>
    }
    else
    {
        @foreach (var order in Model)
        {
            <div class="card shadow-sm border-0 rounded-3 mb-4">
                <div class="card-header bg-white py-3 border-0">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <span class="text-muted small">Дата замовлення:</span>
                            <span class="fw-bold ms-1">@order.OrderDate.ToString("dd.MM.yyyy HH:mm")</span>
                        </div>
                        <div>
                            @* Визначаємо колір бейджа залежно від статусу *@
                            @{
                                var statusName = order.Status?.Name ?? "Нове";
                                var badgeClass = statusName == "Готується" ? "bg-warning text-dark" : "bg-success";
                            }
                            <span class="badge @badgeClass rounded-pill px-3">
                                @statusName
                            </span>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-8">
                            <p class="mb-2 text-muted">
                                <strong>Стіл:</strong> @(order.Place?.Name ?? "Не вказано")
                            </p>
                            <ul class="list-unstyled mb-0">
                                @if (order.OrderFoods != null && order.OrderFoods.Any())
                                {
                                    @foreach (var item in order.OrderFoods)
                                    {
                                        <li class="small py-2 border-bottom-dashed d-flex justify-content-between align-items-center">
                                            <div>
                                                <span class="fw-bold text-primary">@item.Quantity x</span>
                                                <span>@(item.Food?.Name ?? "Страва видалена")</span>
                                            </div>
                                            <span class="text-muted">
                                                @((item.Food?.Price ?? 0) * item.Quantity) грн
                                            </span>
                                        </li>
                                    }
                                }
                                else
                                {
                                    <li class="text-muted small">Список страв порожній</li>
                                }
                            </ul>
                        </div>
                        <div class="col-md-4 text-end d-flex flex-column justify-content-center border-start">
                            <span class="text-muted small">Сума замовлення:</span>
                            <h3 class="text-dark fw-bold">@order.Price грн</h3>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

<style>
    .border-bottom-dashed {
        border-bottom: 1px dashed #dee2e6;
    }

        .border-bottom-dashed:last-child {
            border-bottom: none;
        }
    /* Додаємо легкий акцент на картку при наведенні */
    .card {
        transition: transform 0.2s;
    }

        .card:hover {
            transform: translateY(-3px);
        }
</style>
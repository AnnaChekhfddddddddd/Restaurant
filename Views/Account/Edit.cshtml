@model Restaurant.Models.User

@{
    ViewData["Title"] = "Редагування користувача";
}

<div class="container mt-5 page-transition">
    @* Використовуємо ту саму преміальну картку, що й в інших формах *@
    <div class="premium-card p-5 shadow-sm mx-auto" style="max-width: 900px; border-radius: 30px; background: #fff; border: 1px solid rgba(0,0,0,0.05);">

        <div class="row">
            @* Ліва частина з аватаром *@
            <div class="col-md-4 text-center border-end">
                <div class="position-relative d-inline-block mb-3">
                    <img src="@Model.Avatar" class="rounded-circle shadow" width="150" height="150" style="object-fit: cover; border: 4px solid #fff;" />
                </div>
                <h4 class="fw-bold" style="color: #2d3436;">@Model.FirstName @Model.LastName</h4>
                <span class="badge rounded-pill px-3 py-2" style="background-color: #ffb142; color: white;">@Model.Login</span>
            </div>

            @* Права частина з формою *@
            <div class="col-md-8 ps-md-5">
                <h2 class="fw-bold mb-4" style="color: #2d3436; letter-spacing: -0.5px;">
                    Редагувати <span style="color: #ffb142;">профіль</span>
                </h2>

                <form asp-action="Edit" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    <input type="hidden" asp-for="ID" />
                    <input type="hidden" asp-for="Avatar" />

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label asp-for="FirstName" class="form-label fw-bold mb-2 ms-2" style="color: #636e72;">Ім'я</label>
                            <input asp-for="FirstName" class="form-control form-control-lg rounded-pill px-4"
                                   style="border-color: #f1f1f1; font-size: 1rem; background-color: #fafafa;" />
                            <span asp-validation-for="FirstName" class="text-danger small ms-3"></span>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label asp-for="LastName" class="form-label fw-bold mb-2 ms-2" style="color: #636e72;">Прізвище</label>
                            <input asp-for="LastName" class="form-control form-control-lg rounded-pill px-4"
                                   style="border-color: #f1f1f1; font-size: 1rem; background-color: #fafafa;" />
                            <span asp-validation-for="LastName" class="text-danger small ms-3"></span>
                        </div>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Phone" class="form-label fw-bold mb-2 ms-2" style="color: #636e72;">Телефон</label>
                        <input asp-for="Phone" class="form-control form-control-lg rounded-pill px-4"
                               style="border-color: #f1f1f1; font-size: 1rem; background-color: #fafafa;" placeholder="+380..." />
                        <span asp-validation-for="Phone" class="text-danger small ms-3"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Login" class="form-label fw-bold mb-2 ms-2" style="color: #636e72;">Логін</label>
                        <input asp-for="Login" class="form-control form-control-lg rounded-pill px-4"
                               style="border-color: #f1f1f1; font-size: 1rem; background-color: #fafafa;" />
                        <span asp-validation-for="Login" class="text-danger small ms-3"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Password" class="form-label fw-bold mb-2 ms-2" style="color: #636e72;">Пароль</label>
                        <input asp-for="Password" type="text" class="form-control form-control-lg rounded-pill px-4"
                               style="border-color: #f1f1f1; font-size: 1rem; background-color: #fafafa;" />
                        <span asp-validation-for="Password" class="text-danger small ms-3"></span>
                    </div>

                    @* ОСЬ ТУТ ВИПРАВЛЕНЕ ПОЛЕ ФОТО *@
                    <div class="form-group mb-5">
                        <label class="form-label fw-bold mb-2 ms-2" style="color: #636e72;">Змінити аватар</label>
                        <input type="file" name="file" class="form-control rounded-pill px-4 py-2"
                               style="border-color: #f1f1f1 !important; background-color: #fafafa !important; min-height: 55px !important; line-height: 2.5 !important;" />
                    </div>

                    <div class="mb-3" hidden>
                        <select asp-for="RoleID" class="form-control" asp-items="ViewBag.RoleID"></select>
                    </div>

                    @* Кнопки *@
                    <div class="d-flex gap-3 mt-4">
                        <button type="submit" class="btn btn-warning btn-lg rounded-pill px-5 fw-bold shadow-sm text-white"
                                style="background-color: #27ae60; border: none;">
                            <i class="fa-solid fa-check me-2"></i>Зберегти
                        </button>
                        <a href="javascript:history.back()" class="btn btn-outline-secondary btn-lg rounded-pill px-5 fw-bold">
                            Скасувати
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<style>
    .page-transition {
        animation: fadeIn 0.4s ease-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .form-control:focus {
        border-color: #ffb142 !important;
        box-shadow: 0 0 0 0.25rem rgba(255, 177, 66, 0.1) !important;
        background-color: #fff !important;
    }
</style>
@{
    ViewData["Title"] = "Головна";
}

<div class="container mt-4 page-transition">
    @* --- 1. ГОЛОВНИЙ БАНЕР --- *@
    <div class="premium-card text-center py-5 mb-5"
         style="background: linear-gradient(135deg, #fffaf5 0%, #ffffff 100%); border-radius: 30px; border: 1px solid rgba(0,0,0,0.03);">
        <div class="row align-items-center justify-content-center py-4">
            <div class="col-md-9 col-lg-8">
                <h1 class="display-4 fw-bold mb-3" style="color: #2d3436; letter-spacing: -1px;">
                    Смак <span style="color: #ffb142;">Гурмана</span>, який ви не забудете
                </h1>

                <p class="lead text-muted mb-5 mx-auto" style="max-width: 600px; font-size: 1.15rem; line-height: 1.7;">
                    Бронюйте столики, замовляйте улюблені страви онлайн та насолоджуйтесь ідеальним сервісом нашого закладу.
                </p>

                <div class="d-flex justify-content-center align-items-center">
                    @* Додано me-4 для гарантованого відступу справа *@
                    <a asp-controller="Foods" asp-action="Index"
                       class="btn btn-warning btn-lg rounded-pill px-5 fw-bold shadow me-4"
                       style="background-color: #ffb142; border: none; color: #fff;">
                        Переглянути меню
                    </a>
                    <a asp-controller="Account" asp-action="Register"
                       class="btn btn-outline-dark btn-lg rounded-pill px-5 fw-bold">
                        Доєднатися
                    </a>
                </div>
            </div>
        </div>
    </div>

    @* --- 2. БЛОК ПЕРЕВАГ --- *@
    <div class="row text-center">
        @* Свіжі інгредієнти *@
        <div class="col-md-4 mb-4">
            <div class="premium-card p-4 h-100 border-0 shadow-sm" style="border-radius: 25px; background: #fff;">
                <div class="icon-circle mb-3 mx-auto d-flex align-items-center justify-content-center"
                     style="width: 80px; height: 80px; background: #fff9f2; border-radius: 50%;">
                    @* Листочок тепер точно оранжевий *@
                    <i class="fa-solid fa-leaf fa-2x" style="color: #ffb142;"></i>
                </div>
                <h4 class="fw-bold mb-3">Свіжі інгредієнти</h4>
                <p class="text-muted">Ми працюємо лише з найкращими фермерськими постачальниками.</p>
            </div>
        </div>

        @* Швидка подача *@
        <div class="col-md-4 mb-4">
            <div class="premium-card p-4 h-100 border-0 shadow-sm" style="border-radius: 25px; background: #fff;">
                <div class="icon-circle mb-3 mx-auto d-flex align-items-center justify-content-center"
                     style="width: 80px; height: 80px; background: #fff9f2; border-radius: 50%;">
                    <i class="fa-solid fa-truck-fast fa-2x" style="color: #ffb142;"></i>
                </div>
                <h4 class="fw-bold mb-3">Швидка подача</h4>
                <p class="text-muted">Ваше замовлення буде на столі гарячим в найкоротший термін.</p>
            </div>
        </div>

        @* Атмосфера *@
        <div class="col-md-4 mb-4">
            <div class="premium-card p-4 h-100 border-0 shadow-sm" style="border-radius: 25px; background: #fff;">
                <div class="icon-circle mb-3 mx-auto d-flex align-items-center justify-content-center"
                     style="width: 80px; height: 80px; background: #fff9f2; border-radius: 50%;">
                    <i class="fa-solid fa-star fa-2x" style="color: #ffb142;"></i>
                </div>
                <h4 class="fw-bold mb-3">Атмосфера</h4>
                <p class="text-muted">Затишний та сучасний інтер'єр для ваших найкращих спогадів.</p>
            </div>
        </div>
    </div>
</div>

<style>
    .container {
        max-width: 1140px !important;
    }

    .premium-card {
        transition: all 0.3s ease;
    }

        .premium-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.1) !important;
        }

    .btn:hover {
        transform: scale(1.05);
        filter: brightness(1.1);
    }
</style>